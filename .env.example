# Backend endpoint that returns a LiveKit access token.
# Called as: POST {VITE_TOKEN_ENDPOINT}
# Body: { "agent_name": "Vani", "id": "web-xxxx" }
# Expected JSON response: { "success": true, "message": "token created", "data": { "token": "...", "url": "wss://..." } }
VITE_TOKEN_ENDPOINT=https://your-backend.example.com/token

# Optional fallback if your endpoint returns only a token and no url.
VITE_LIVEKIT_URL=

# Optional: name shown in the widget header.
VITE_AGENT_NAME=Vani
